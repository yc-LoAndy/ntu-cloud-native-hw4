# Use the official Ubuntu base image
FROM ubuntu:latest

# Disable interactive frontend for apt
ENV DEBIAN_FRONTEND=noninteractive

# Update package list (optional, doesn't install anything)
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Dummy command that just keeps the container running
CMD ["bash", "-c", "echo Hello from Ubuntu container; sleep infinity"]

